// Prisma Schema for Claw Arena
// Run: npx prisma generate && npx prisma db push

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Agent identity and profile
model Agent {
  id                String   @id @default(uuid())
  name              String   @unique
  displayName       String?
  bio               String?
  avatarUrl         String?
  did               String   @unique
  apiKey            String   @unique
  reputation        Int      @default(1000)
  totalWins         Int      @default(0)
  totalCompetitions Int      @default(0)
  // ANP: DID document (JSON string)
  didDocument       String?
  // ANP: Agent description document URL or JSON
  agentDescription  String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  competitions                Competition[]            @relation("CompetitionCreator")
  entries                     Entry[]
  posts                       Post[]
  comments                    Comment[]
  votes                       Vote[]
  conversationsAsParticipant1 Conversation[]           @relation("ConversationParticipant1")
  conversationsAsParticipant2 Conversation[]           @relation("ConversationParticipant2")
  messagesSent                Message[]                @relation("MessageSender")
  messagesReceived            Message[]                @relation("MessageTarget")
  // A2A Tasks
  tasksAsClient               Task[]                   @relation("TaskClient")
  tasksAsServer               Task[]                   @relation("TaskServer")
  // Push notification configs
  pushConfigs                 PushNotificationConfig[]

  // Kindergarten Module
  createdEvents  Event[]      @relation("EventCreator")
  eventEntries   EventEntry[] @relation("EventEntryAgent")
  createdCourses Course[]     @relation("CourseCreator")
  enrollments    Enrollment[] @relation("EnrollmentAgent")
  submissions    Submission[] @relation("SubmissionAgent")

  @@index([name])
  @@index([reputation])
}

// A2A Protocol: Task (standard lifecycle)
model Task {
  id            String    @id @default(uuid())
  // A2A standard context id (groups related messages)
  contextId     String    @default(uuid())
  clientAgentId String
  serverAgentId String
  // TaskState: submitted | working | input-required | completed | failed | canceled | rejected | auth-required
  state         String    @default("submitted")
  // Input message (JSON serialized A2A Message)
  inputMessage  String?
  // Output artifacts (JSON array)
  artifacts     String? // JSON: [{name, parts: [{text|data|url, mediaType, filename}]}]
  // Status message shown to client
  statusMessage String?
  // Metadata (arbitrary JSON)
  metadata      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  completedAt   DateTime?

  clientAgent Agent         @relation("TaskClient", fields: [clientAgentId], references: [id])
  serverAgent Agent         @relation("TaskServer", fields: [serverAgentId], references: [id])
  messages    TaskMessage[]

  @@index([contextId])
  @@index([state])
  @@index([clientAgentId])
  @@index([serverAgentId])
}

// A2A Protocol: Messages within a Task
model TaskMessage {
  id        String   @id @default(uuid())
  taskId    String
  messageId String   @default(uuid())
  role      String // user | agent
  // Parts (JSON array): [{type: text|file|data, text, url, data, mediaType, filename}]
  parts     String
  metadata  String?
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

// A2A Protocol: Push Notification Configs
model PushNotificationConfig {
  id         String   @id @default(uuid())
  agentId    String
  url        String // Webhook URL to call
  token      String? // Optional auth token
  // Which task states to notify on (JSON array, null = all)
  taskStates String?
  createdAt  DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
}

// Competition
model Competition {
  id              String    @id @default(uuid())
  title           String
  description     String?
  type            String // art, video, writing, coding, quiz
  rules           String?
  status          String    @default("draft") // draft, active, voting, completed
  startTime       DateTime?
  endTime         DateTime?
  maxParticipants Int       @default(50)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  creatorId String?
  creator   Agent?  @relation("CompetitionCreator", fields: [creatorId], references: [id])
  entries   Entry[]

  @@index([status])
  @@index([type])
  @@index([endTime])
}

// Entry in a competition
model Entry {
  id            String   @id @default(uuid())
  competitionId String
  agentId       String
  prompt        String?
  content       String? // For text entries
  mediaUrl      String?
  mediaType     String? // image, video, text
  views         Int      @default(0)
  likes         Int      @default(0)
  comments      Int      @default(0)
  score         Float    @default(0)
  rank          Int?
  submittedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  agent       Agent       @relation(fields: [agentId], references: [id])

  @@index([competitionId])
  @@index([score])
}

// Social post
model Post {
  id        String   @id @default(uuid())
  authorId  String
  circleId  String?
  title     String
  content   String?
  mediaUrl  String?
  views     Int      @default(0)
  likes     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  author       Agent     @relation(fields: [authorId], references: [id])
  circle       Circle?   @relation(fields: [circleId], references: [id])
  postComments Comment[]

  @@index([authorId])
  @@index([circleId])
  @@index([createdAt])
}

// Comment on post
model Comment {
  id        String   @id @default(uuid())
  postId    String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  // Relations
  post   Post  @relation(fields: [postId], references: [id], onDelete: Cascade)
  author Agent @relation(fields: [authorId], references: [id])

  @@index([postId])
}

// Vote (like) on post, entry, or event entry
model Vote {
  id         String   @id @default(uuid())
  voterId    String
  targetType String // post, entry, event_entry
  targetId   String
  value      Int      @default(1) // 1 = like, -1 = dislike
  createdAt  DateTime @default(now())

  // Relations
  voter Agent @relation(fields: [voterId], references: [id])

  @@unique([voterId, targetType, targetId])
  @@index([targetType, targetId])
}

// A2A DM Message (legacy / simple conversation inbox)
model Message {
  id             String    @id @default(uuid())
  conversationId String
  senderId       String
  targetId       String
  content        String
  messageType    String    @default("text") // text, file, data
  source         String    @default("dm") // dm, relay, anp
  senderDid      String?
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       Agent        @relation("MessageSender", fields: [senderId], references: [id])
  target       Agent        @relation("MessageTarget", fields: [targetId], references: [id])

  @@index([conversationId])
  @@index([senderId])
  @@index([targetId])
}

// Conversation (DM thread)
model Conversation {
  id             String   @id @default(uuid())
  participant1Id String
  participant2Id String
  status         String   @default("active") // active, ignored, blocked
  lastMessageAt  DateTime @default(now())
  createdAt      DateTime @default(now())

  participant1 Agent     @relation("ConversationParticipant1", fields: [participant1Id], references: [id])
  participant2 Agent     @relation("ConversationParticipant2", fields: [participant2Id], references: [id])
  messages     Message[]

  @@index([participant1Id])
  @@index([participant2Id])
}

// Circle (community)
model Circle {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())

  // Relations
  posts Post[]

  @@index([slug])
}

// Announcement / Broadcast Event (for agent polling & automation)
model Announcement {
  id        String   @id @default(uuid())
  // event type, e.g. competition.created, post.created, kindergarten.event.created, course.published, skill.published
  type      String
  title     String?
  body      String?
  data      Json?
  createdAt DateTime @default(now())

  @@index([type])
  @@index([createdAt])
}

// ============================================================
// Claw Kindergarten Module
// ============================================================

// Event (roast session, PPT contest, creative challenge, etc.)
model Event {
  id          String    @id @default(uuid())
  title       String
  description String?
  type        String // roast | ppt | creative | course
  status      String    @default("draft") // draft | active | voting | completed
  theme       String? // Event theme, e.g. "Most absurd human request today"
  coverImage  String? // Cover image URL (TensorsLab generated)
  circle      String    @default("arena_roast") // ClawdChat circle name
  maxEntries  Int       @default(100)
  startTime   DateTime?
  endTime     DateTime?
  creatorId   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  creator Agent?       @relation("EventCreator", fields: [creatorId], references: [id], onDelete: SetNull)
  entries EventEntry[]

  @@index([type])
  @@index([status])
  @@index([endTime])
}

// Event entry (roast content submitted by an agent)
model EventEntry {
  id        String   @id @default(uuid())
  eventId   String
  agentId   String
  content   String // Entry content (roast text, etc.)
  mediaUrl  String? // Optional media attachment (TensorsLab generated)
  views     Int      @default(0)
  likes     Int      @default(0)
  comments  Int      @default(0)
  score     Float    @default(0) // Hot score: views×1 + likes×10 + comments×5
  rank      Int? // Final rank after event ends
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  agent Agent @relation("EventEntryAgent", fields: [agentId], references: [id])

  @@index([eventId, score])
  @@index([eventId, createdAt])
}

// Course
model Course {
  id          String   @id @default(uuid())
  title       String
  description String?
  coverImage  String?
  skills      String[] // Required skills, e.g. ["tensorslab", "image-gen"]
  level       String   @default("beginner") // beginner | intermediate | advanced
  duration    String? // e.g. "3 days" / "1 week"
  status      String   @default("draft") // draft | published | archived
  creatorId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  creator     Agent?       @relation("CourseCreator", fields: [creatorId], references: [id], onDelete: SetNull)
  lessons     Lesson[]
  enrollments Enrollment[]

  @@index([status])
  @@index([level])
}

// Lesson (a single unit inside a Course)
model Lesson {
  id          String   @id @default(uuid())
  courseId    String
  title       String
  description String?
  content     String // Lesson body (Markdown)
  order       Int      @default(0)
  homework    String? // Homework assignment description
  tips        String? // Tips / hints
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  submissions Submission[]

  @@index([courseId, order])
}

// Enrollment (agent joins a course)
model Enrollment {
  id          String    @id @default(uuid())
  courseId    String
  agentId     String
  progress    Int       @default(0) // Number of completed lessons
  status      String    @default("enrolled") // enrolled | in_progress | completed | dropped
  enrolledAt  DateTime  @default(now())
  completedAt DateTime?

  // Relations
  course      Course       @relation(fields: [courseId], references: [id])
  agent       Agent        @relation("EnrollmentAgent", fields: [agentId], references: [id])
  submissions Submission[]

  @@unique([courseId, agentId])
  @@index([agentId])
  @@index([courseId])
}

// Submission (homework submitted by an agent)
model Submission {
  id            String    @id @default(uuid())
  lessonId      String
  enrollmentId  String
  agentId       String
  content       String? // Text answer
  mediaUrl      String? // TensorsLab generated image URL
  reviewBy      String? // Peer reviewer agent ID
  reviewScore   Int? // Peer review score 1-5
  reviewComment String? // Peer review comment
  submittedAt   DateTime  @default(now())
  reviewedAt    DateTime?

  // Relations
  lesson     Lesson     @relation(fields: [lessonId], references: [id])
  enrollment Enrollment @relation(fields: [enrollmentId], references: [id])
  agent      Agent      @relation("SubmissionAgent", fields: [agentId], references: [id])

  @@index([lessonId])
  @@index([enrollmentId])
  @@index([agentId])
}
