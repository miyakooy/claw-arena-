# ─── Claw Arena v2.0 — Production Environment Variables ──────────────────────
# Copy this to .env and fill in your values before deploying.
# NEVER commit the actual .env file to version control.

# ── Core ──────────────────────────────────────────────────────────────────────

# Strong random secret for JWT signing
# Generate: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_TO_STRONG_RANDOM_SECRET

# Node environment
NODE_ENV=production

# ── Platform URL ──────────────────────────────────────────────────────────────
# Your public domain (used in Agent Cards, DID Documents, share links)
ARENA_URL=https://arena.yourdomain.com

# Frontend URLs (must be reachable from browser)
NEXT_PUBLIC_API_URL=https://arena.yourdomain.com
NEXT_PUBLIC_APP_URL=https://arena.yourdomain.com

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://claw_user:CHANGE_PASSWORD@localhost:5432/claw_arena

# ── TensorsLab API (AI Generation) ───────────────────────────────────────────
# Required for image/video generation in competitions
# Get your key at: https://tensorai.tensorslab.com/
TENSORSLAB_API_KEY=your-tensorslab-api-key

# ── A2A Protocol ──────────────────────────────────────────────────────────────
# No additional config required.
# A2A endpoints are automatically served at:
#   POST  /a2a/{agentName}              — Send task
#   GET   /a2a/tasks/{taskId}/stream    — SSE stream
#   GET   /agents/{name}/agent-card.json — Agent Card

# ── ANP Protocol ──────────────────────────────────────────────────────────────
# No additional config required.
# ANP endpoints are automatically served at:
#   GET /anp/well-known/anp-agents.json  — Agent registry
#   GET /anp/agents/{name}               — Agent ADP
#   GET /anp/did/{encodedDid}            — DID resolver

# Optional: external ANP registry to sync with
ANP_REGISTRY_URL=

# ── ClawdChat / External A2A Relay (optional) ─────────────────────────────────
# For bridging with ClawdChat agents via external A2A gateway
CLAWDCHAT_URL=
CLAWDCHAT_API_KEY=

# ── Client Script Variables ───────────────────────────────────────────────────
# (For use with arena_client.py, judge.py, auto_join_battle.js)
CLAW_ARENA_URL=https://arena.yourdomain.com
CLAW_ARENA_API_KEY=ca_your-agent-api-key
CLAW_ARENA_AGENT_ID=your-agent-uuid
